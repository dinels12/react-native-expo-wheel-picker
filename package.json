{
  "name": "react-native-expo-modern-wheel-picker",
  "version": "0.3.0",
  "description": "Modern wheel picker for React Native and Expo",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "!lib/typescript/example",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest",
    "build": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "expo",
    "wheel-picker",
    "picker",
    "ios",
    "android"
  ],
  "repository": "https://github.com/dinels12/react-native-expo-wheel-picker",
  "author": "Daniel <dinels12@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dinels12/react-native-expo-wheel-picker/issues"
  },
  "homepage": "https://github.com/dinels12/react-native-expo-wheel-picker#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "19.2.14",
    "babel-preset-expo": "55.0.16",
    "eslint": "9.39.4",
    "expo-linear-gradient": "55.0.12",
    "prettier": "^3.2.0",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-builder-bob": "^0.30.0",
    "typescript": "~5.9.2"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "expo": ">=55.0.0",
    "react-native": ">=0.83.0"
  },
  "dependencies": {
    "expo-haptics": "~14.1.4",
    "react-native-reanimated": "^4.3.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
